// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String  @id @default(uuid())
  email          String  @unique
  password       String
  name           String?
  image          String?
  emailVerified  Boolean  @default(false)

  sessions       Session[]
  products       Product[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}


model Session {
  id            String @id @default(cuid())
  sessionToken  String @unique
  userId        String
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt     DateTime
  userAgent     String?
  ipAddress     String?
  createdAt     DateTime @default(now())

  @@index([userId])
}


model Verification {
  id          String @id @default(cuid())
  identifier  String
  token       String @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([identifier, token])
}

model Category {
  id        String      @id @default(uuid())
  name      String      @unique
  products  Product[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  price       Decimal     @db.Decimal(10, 2)
  stock       Int

  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}